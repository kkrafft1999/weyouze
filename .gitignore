# Dependencies
node_modules/

# Python virtual env
.venv/
venv/
__pycache__/
*.pyc

# Build output
out/
dist/
build/

# Auto-generated vendor bundle
src/renderer/vendor/*.js
src/preload/bundle.js

# Logs
*.log
npm-debug.log*

# Environment / secrets
.env
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# Cursor: Projektregeln unter .cursor/rules/ versionieren;
# übrige Agent-/Cache-Daten (z. B. .cursor/projects) lokal ignorieren
.cursor/*
!.cursor/rules/
!.cursor/rules/**

# Claude Code: geteilte Skills unter .claude/skills/ versionieren;
# persoenliche Settings/Caches (settings*.json u. a.) lokal ignorieren
.claude/*
!.claude/skills/
!.claude/skills/**
